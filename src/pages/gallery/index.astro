---

<Layout {...seo}>
    <Header solid={true} />
    <section
        class="py-12 md:py-20 bg-linear-to-br from-secondary via-secondary/90 to-primary relative overflow-hidden min-h-screen"
    >
        <div class="container mx-auto px-4 md:px-6 relative z-10 mt-20 md:mt-16">
            <div class="max-w-7xl mx-auto">
                <header
                    class="relative text-3xl md:text-5xl font-bold text-white text-center mb-8 md:mb-16"
                >
                    Gallery
                    <span
                        class="absolute top-10 md:top-14 left-1/2 -translate-x-1/2 w-24 md:w-44 h-1 bg-primary"
                    ></span>
                </header>
                <p class="text-base md:text-xl opacity-90 text-white text-center mb-8 md:mb-12 px-4">
                    Explore our curated collection of stunning images that
                    capture the essence of travel and adventure.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[200px] sm:auto-rows-[220px] md:auto-rows-[240px] gap-3 md:gap-5">
                    {
                        photos.map((photo) => (
                            <div
                                class={`${photo.className} group cursor-pointer relative overflow-hidden rounded-2xl md:rounded-3xl bg-white shadow-lg hover:shadow-2xl transition-all duration-500`}
                            >
                                <div class="absolute inset-0 transition-transform duration-700 ease-out md:group-hover:rotate-[5deg] md:group-hover:scale-110">
                                    <Image
                                        src={photo.src}
                                        alt={photo.alt}
                                        width={1080}
                                        height={720}
                                        class="w-full h-full object-cover"
                                        style={`object-position: ${photo.objectPosition || "center"};`}
                                        loading={"eager"}
                                    />
                                </div>

                                {/* linear overlay */}
                                <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent opacity-70 md:opacity-60 md:group-hover:opacity-80 transition-opacity duration-500" />

                                {/* Content */}
                                <div class="absolute inset-0 p-4 md:p-8 flex flex-col justify-end">
                                    <div class="transform md:translate-y-2 md:group-hover:translate-y-0 transition-transform duration-500">
                                        <h3 class="text-white text-base md:text-lg mb-1">
                                            {photo.title}
                                        </h3>
                                        <p class="text-white/80 text-sm md:text-base opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500 delay-100">
                                            {photo.subtitle}
                                        </p>
                                    </div>
                                </div>

                                {/* Shine effect - only on desktop */}
                                <div class="absolute inset-0 opacity-0 md:group-hover:opacity-100 transition-opacity duration-700 hidden md:block">
                                    <div class="absolute top-0 -left-full h-full w-1/2 bg-linear-to-r from-transparent via-white/20 to-transparent skew-x-12 group-hover:left-full transition-all duration-1000" />
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>
    <Footer />
</Layout>
